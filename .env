# KB Service Environment Variables

# Redis Queue Configuration
# 文件大小阈值，超过此大小的文件将使用队列异步处理
# 支持多种格式: 字节数(1048576) 或 带单位(1M, 1MB, 1m, 1mb)
# 默认值: 1MB
QUEUE_SIZE_THRESHOLD=2M

# Redis Connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=Pass@1234

# RQ Dashboard
RQ_DASHBOARD_PORT=9090

# Dify Knowledge Base
DIFY_BASE_URL=http://localhost:8000/v1
